# Site
NEXT_PUBLIC_SITE_URL=https://dev-aditya.com

# Instagram — primary contact channel for the free homepage sample offer.
# Must be the full profile URL, e.g.
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/your.handle
# When unset, the free-sample button falls back to a pre-filled email.
NEXT_PUBLIC_INSTAGRAM_URL=

# Database (Neon PostgreSQL pooled connection string)
DATABASE_URL=

# Google PageSpeed Insights
GOOGLE_PAGESPEED_API_KEY=

# Resend
RESEND_API_KEY=
AUDIT_FROM_EMAIL=Aditya Website Audit <audit@dev-aditya.com>
AUDIT_NOTIFICATION_EMAIL=hi.aditya.dev@gmail.com

# Audit security
AUDIT_SIGNING_SECRET=
IP_HASH_SECRET=
AUDIT_FEATURE_ENABLED=true

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Testing only — never set to true in production
AUDIT_USE_FIXTURES=false
